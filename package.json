{
  "name": "rimless",
  "author": "Aurélien Franky",
  "version": "0.7.1",
  "license": "MIT",
  "homepage": "https://github.com/au-re/rimless",
  "description": "event base communication made easy with a promise-based API wrapping `postMessage`",
  "type": "module",
  "main": "lib/rimless.js",
  "module": "lib/rimless.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && tsc --noEmit -p tsconfig.test.json && vite build",
    "prepublishOnly": "bun run build",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:browser": "npm run build && node tests/browser/opaque-origin-iframe.mjs",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "visualize-bundle": "bunx vite-bundle-visualizer",
    "changeset": "changeset",
    "release": "bun run build && changeset publish",
    "validate": "bun run format:check && bun run lint && bun run build && bun run test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/au-re/rimless.git"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@changesets/cli": "2.30.0",
    "@chromatic-com/storybook": "^4.1.1",
    "@storybook/addon-docs": "^9.1.15",
    "@storybook/addon-links": "^9.1.15",
    "@storybook/addon-onboarding": "^9.1.15",
    "@storybook/react-vite": "^9.1.15",
    "@types/lodash.set": "^4.3.9",
    "@types/node": "^24.9.1",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "4.0.3",
    "happy-dom": "^20.0.8",
    "storybook": "^9.1.15",
    "terser": "^5.44.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "4.0.3"
  },
  "engines": {
    "bun": ">=1.3.13"
  },
  "packageManager": "bun@1.3.13",
  "volta": {
    "node": "22.21.0"
  }
}
